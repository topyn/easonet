# ── Database (Vercel Postgres or Supabase) ─────────────────────────────────
POSTGRES_PRISMA_URL="postgresql://user:pass@host:5432/db?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:pass@host:5432/db"

# ── Supabase Auth ──────────────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ── Brevo SMTP (outbound email) ────────────────────────────────────────────
# From: brevo.com → SMTP & API → SMTP
BREVO_SMTP_USER="your-login@email.com"
BREVO_SMTP_KEY="your-smtp-key"

# ── Stripe (billing) ───────────────────────────────────────────────────────
# From: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create 3 products in Stripe dashboard, paste the Price IDs here:
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_GROWTH_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# ── Inbound webhook secret ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Paste same value into Cloudflare Worker or Brevo webhook config
INBOUND_WEBHOOK_SECRET="generate-a-long-random-string"

# ── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.easonet.com"
