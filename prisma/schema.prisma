generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                String     @id @default(cuid())
  supabaseId        String     @unique
  email             String     @unique
  stripeCustomerId  String?
  stripeSubId       String?
  plan              String     @default("trial")  // trial | starter | growth | pro
  trialEndsAt       DateTime?
  createdAt         DateTime   @default(now())
  identities        Identity[]
  threads           Thread[]
  waitlists         Waitlist[]
  stores Store[]
}

model Identity {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  name         String
  email        String    @unique
  domain       String
  color        String    @default("#534AB7")
  dnsVerified  Boolean   @default(false)
  smtpHost     String
  smtpPort     Int       @default(587)
  smtpUser     String
  smtpPass     String
  createdAt    DateTime  @default(now())
  threads      Thread[]
  sentMessages Message[] @relation("SentMessages")
  waitlists    Waitlist[]
  stores Store[]
}

model Thread {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  subject      String
  identityId   String
  identity     Identity  @relation(fields: [identityId], references: [id])
  participants String[]
  read         Boolean   @default(false)
  lastAt       DateTime  @default(now())
  createdAt    DateTime  @default(now())
  messages     Message[]
}

model Message {
  id               String    @id @default(cuid())
  threadId         String
  thread           Thread    @relation(fields: [threadId], references: [id])
  direction        String    // "inbound" | "outbound"
  fromAddress      String
  toAddress        String
  subject          String
  bodyText         String    @db.Text
  bodyHtml         String?   @db.Text
  rawMessageId     String?
  sentByIdentityId String?
  sentByIdentity   Identity? @relation("SentMessages", fields: [sentByIdentityId], references: [id])
  createdAt        DateTime  @default(now())
}

model Waitlist {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  identityId   String?
  identity     Identity?        @relation(fields: [identityId], references: [id])
  name         String
  slug         String           @unique
  headline     String           @default("Get early access")
  description  String?
  buttonText   String           @default("Join waitlist")
  thankYouMsg  String           @default("You're on the list! We'll be in touch.")
  showCount    Boolean          @default(true)
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  signups      WaitlistSignup[]
}

model WaitlistSignup {
  id         String   @id @default(cuid())
  waitlistId String
  waitlist   Waitlist @relation(fields: [waitlistId], references: [id])
  email      String
  name       String?
  createdAt  DateTime @default(now())

  @@unique([waitlistId, email])
}

model Store {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  identityId  String?
  identity    Identity? @relation(fields: [identityId], references: [id])
  name        String
  slug        String    @unique
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]
  orders      Order[]
}

model Product {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  name         String
  description  String?
  price        Float
  currency     String   @default("USD")
  type         String   @default("digital")
  imageUrl     String?
  fileUrl      String?
  deliveryNote String?
  stock        Int?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Order {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  buyerEmail    String
  buyerName     String
  buyerAddress  String?
  quantity      Int      @default(1)
  total         Float
  currency      String   @default("USD")
  status        String   @default("pending")
  paypalOrderId String?
  createdAt     DateTime @default(now())
}